# Copier vers ~/dotfiles/.env puis renseigner les valeurs sensibles.
# cp .env.example .env && chmod 600 .env
# Ce fichier est versionné ; .env est dans .gitignore et ne doit jamais être commité.

# --- VPS principal (utilisateur applicatif) ---
SSH_HOST_NAME="pavel-server"
SSH_HOST="95.111.227.204"
SSH_USER="pavel"
SSH_PORT="22"
# Mot de passe : uniquement pour la première copie de clé (ssh-auto). Ensuite connexion par clé.
SSH_PASSWORD=""

# Optionnel : compte root (ne pas utiliser au quotidien ; préférer sudo sur pavel)
# SSH_ROOT_PASSWORD=""

# Git (utilisé aussi comme commentaire de clé SSH si génération)
# GIT_USER_EMAIL="vous@example.com"
