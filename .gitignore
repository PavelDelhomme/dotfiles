#*
#!.zshrc
#!.zshenv
#!.zsh/

# Logs (tout le dossier logs/)
logs/
*.log

# Documentation générée
zsh/functions_doc.json
zsh/aliases_doc.json

# Fichier d'environnement avec informations sensibles
.env

# Préférences locales pour les tests Docker (voir scripts/test/config/test.local.env.example)
scripts/test/config/test.local.env

# Sorties des tests Docker / matrice (régénérées à chaque run)
test_results/

# Binaire local (make build-dotcli)
bin/dotcli

# Imports / diagnostics locaux (ne pas versionner par défaut)
run/artifacts/home-import/

# Fichiers de sauvegarde
*.save
*.bak
*.backup
zsh/backups/
scripts/.ssh/
scripts/.gitconfig
