# =============================================================================
# Dockerfile CentOS pour tests automatisés des dotfiles
# =============================================================================
# Description: Image Docker CentOS isolée pour tester les dotfiles
# Author: Paul Delhomme
# Version: 1.0
# =============================================================================

# CentOS Stream / RHEL family — image Rocky Linux (centos:latest EOL sur Docker Hub).
FROM rockylinux:9

# Variables d'environnement
ENV DOTFILES_DIR=/root/dotfiles
ENV HOME=/root
ENV TERM=xterm-256color

# Installer les dépendances de base
RUN dnf update -y && \
    dnf install -y \
        git wget zsh python3 python3-pip \
        gcc gcc-c++ make sudo vim nano \
        && (dnf install -y fish man-db 2>/dev/null || true) && \
    dnf clean all && \
    rm -rf /var/cache/dnf/*

# Créer le répertoire dotfiles
WORKDIR /root

# Script d'initialisation pour charger les dotfiles
RUN printf '#!/bin/sh\n# Entrypoint pour charger les dotfiles\nexport DOTFILES_DIR=/root/dotfiles\nexport DOTFILES_ZSH_PATH="$DOTFILES_DIR/zsh"\n# Message d aide pour quitter\nif [ -t 0 ]; then\n    echo ""\n    echo "💡 Pour quitter le conteneur: tapez exit ou appuyez sur Ctrl+D"\n    echo ""\nfi\nexec "$@"\n' > /root/entrypoint.sh && \
    chmod +x /root/entrypoint.sh

ENTRYPOINT ["/root/entrypoint.sh"]
CMD ["/bin/zsh"]

