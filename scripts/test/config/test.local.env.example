# Copier vers test.local.env (non versionné) pour éviter de retaper les variables.
#   cp scripts/test/config/test.local.env.example scripts/test/config/test.local.env
#
# Les tests Docker ne chargent PAS ce fichier dans votre shell interactif :
# seul le script d’entrée Docker le source sur l’hôte avant `docker run`.
#
# Exemples (décommenter / adapter) :

# Un seul shell, tous les managers migrés (matrice + manager_tester) :
# TEST_SHELLS=zsh

# Seulement searchman + pathman (matrice sous-commandes ou tests managers) :
# TEST_MANAGERS="searchman pathman"

# Matrice sous-commandes : seulement la première ligne de chaque .list :
# SUBCOMMAND_TIER=quick

# Copie le dépôt dans /tmp avant montage : votre ~/dotfiles n’est plus bindé
# (utile si vous craignez un futur montage RW par erreur ; plus lent) :
# TEST_DOTFILES_ISOLATE=1

# Désactiver la matrice sous-commandes dans le gros flux test-docker :
# RUN_SUBCOMMAND_MATRIX=0

# --- installman (conteneur ou shell de test) ---
# Accepter toutes les confirmations (idéal dans Docker pour essayer un module) :
# INSTALLMAN_ASSUME_YES=1
# Exemple pyenv : plusieurs versions puis global pyenv (à lancer hors menu si besoin) :
# PYENV_VERSIONS="3.12.3"
# PYENV_GLOBAL_VERSION=3.12.3
# Clone d’un autre dépôt perso :
# DOTFILES_USER_PROJECT_GIT_URL="https://github.com/vous/autre-projet.git"
# DOTFILES_USER_PROJECT_DIR="$HOME/src/autre-projet"
